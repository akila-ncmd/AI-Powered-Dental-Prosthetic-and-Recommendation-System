{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Next.js: Dev (server-side debugging)",
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "--inspect=9229"
            ],
            "program": "${workspaceFolder}/node_modules/next/dist/bin/next",
            "args": [
                "dev",
                "-p",
                "3001"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "outFiles": [
                "${workspaceFolder}/.next/**/*.js"
            ]
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Next.js: Client (Chrome)",
            "url": "http://localhost:3001",
            "webRoot": "${workspaceFolder}"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Next.js: Start (prod, server-side debugging)",
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "--inspect=9230"
            ],
            "program": "${workspaceFolder}/node_modules/next/dist/bin/next",
            "args": [
                "start",
                "-p",
                "3000"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "skipFiles": [
                "<node_internals>/**"
            ]
        }
    ],
    "compounds": [
        {
            "name": "Next.js: Full Stack",
            "configurations": [
                "Next.js: Dev (server-side debugging)",
                "Next.js: Client (Chrome)"
            ]
        }
    ]
}